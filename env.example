# Twitter Developer credentials
# Obtain from: https://developer.twitter.com/en/portal/dashboard
TWITTER_CONSUMER_KEY=your_twitter_consumer_key_here
TWITTER_CONSUMER_SECRET=your_twitter_consumer_secret_here

# IBM Watson Tone Analyzer credentials
# Obtain from: https://cloud.ibm.com/catalog/services/tone-analyzer
WATSON_USERNAME=your_watson_service_username_here
WATSON_PASSWORD=your_watson_service_password_or_api_key_here
